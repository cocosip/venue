{
  "metadataDirectory": "./venue-data/metadata",
  "quotaDirectory": "./venue-data/quota",
  "fileWatcherConfigurationDirectory": "./venue-data/watchers",
  "autoCreateTenants": true,
  "defaultTenantQuota": 0,
  "enableDatabaseHealthCheck": true,
  "retryPolicy": {
    "maxRetryCount": 3,
    "initialRetryDelay": 5000000000,
    "useExponentialBackoff": true,
    "maxRetryDelay": 300000000000
  },
  "volumes": [
    {
      "volumeId": "vol-001",
      "mountPath": "./venue-data/storage/volume-1",
      "volumeType": "LocalFileSystem",
      "shardingDepth": 2
    },
    {
      "volumeId": "vol-002",
      "mountPath": "./venue-data/storage/volume-2",
      "volumeType": "LocalFileSystem",
      "shardingDepth": 2
    }
  ],
  "tenants": [
    {
      "tenantId": "tenant-001",
      "enabled": true,
      "quota": 10000000
    },
    {
      "tenantId": "tenant-002",
      "enabled": true,
      "quota": null
    },
    {
      "tenantId": "tenant-disabled",
      "enabled": false,
      "quota": null
    }
  ],
  "fileWatchers": [
    {
      "watcherId": "watcher-vip-tenant-001",
      "tenantId": "tenant-001",
      "multiTenantMode": false,
      "autoCreateTenantDirectories": false,
      "watchPath": "./venue-data/watch/vip/tenant-001",
      "enabled": true,
      "includeSubdirectories": true,
      "filePatterns": [
        "*.pdf",
        "*.docx",
        "*.xlsx"
      ],
      "postImportAction": "Delete",
      "moveToDirectory": "",
      "pollingInterval": 10000000000,
      "maxFileSizeBytes": 104857600,
      "minFileAge": 3000000000,
      "maxConcurrentImports": 16
    },
    {
      "watcherId": "watcher-all-regular-tenants",
      "tenantId": "",
      "multiTenantMode": true,
      "autoCreateTenantDirectories": true,
      "watchPath": "./venue-data/watch/shared",
      "enabled": true,
      "includeSubdirectories": true,
      "filePatterns": [
        "*.*"
      ],
      "postImportAction": "Delete",
      "moveToDirectory": "",
      "pollingInterval": 30000000000,
      "maxFileSizeBytes": 0,
      "minFileAge": 5000000000,
      "maxConcurrentImports": 8
    }
  ],
  "enableBackgroundCleanup": true,
  "cleanupOptions": {
    "cleanupInterval": 3600000000000,
    "initialDelay": 60000000000,
    "cleanupEmptyDirectories": true,
    "cleanupTimedOutFiles": true,
    "processingTimeout": 1800000000000,
    "cleanupPermanentlyFailedFiles": true,
    "failedFileRetentionPeriod": 604800000000000,
    "cleanupCompletedRecords": false,
    "completedRecordRetentionPeriod": 2592000000000000,
    "optimizeDatabases": true,
    "databaseOptimizationInterval": 86400000000000
  },
  "databaseHealthCheckOptions": {
    "initialDelay": 2000000000,
    "maxRetries": 3,
    "retryDelay": 1000000000,
    "checkOnStartupOnly": true,
    "periodicCheckInterval": 3600000000000
  }
}